# gospel-engine environment configuration
#
# Copy to .env (or paste into Dokploy → Environment) and fill in values.
# Every variable below has a safe default EXCEPT GOSPEL_DB, which you must
# set to point at the Postgres instance.
#
# ===========================================================================

# --- HTTP ---
# The port the server listens on inside the container. Dokploy maps 8080 → 443
# via its Traefik reverse proxy, so you normally don't need to change this.
LISTEN_ADDR=:8080

# --- Database (REQUIRED) ---
# Full PostgreSQL connection string. In Dokploy, point this at your
# engine-db service by its internal service name (not localhost).
# The database user needs permission to CREATE EXTENSION (pgvector, pg_trgm).
# Example values:
#   Dokploy, same project:  postgres://gospel:PASSWORD@engine-db:5432/gospel?sslmode=disable
#   External managed PG:    postgres://user:pass@host.example.com:5432/gospel?sslmode=require
GOSPEL_DB=postgres://gospel:CHANGEME@engine-db:5432/gospel?sslmode=disable

# --- Embedding server ---
# OpenAI-compatible /v1/embeddings endpoint. On NOCIX this is a local
# LM Studio / Ollama instance on the host. From inside the container,
# `host.docker.internal` resolves to the host if you set it up (Docker
# Desktop does this automatically; for Dokploy/Linux you may need
# `--add-host host.docker.internal:host-gateway` in the container config).
#
# You can also point this at any OpenAI-compatible service that serves
# nomic-embed-text-v1.5 at 768 dimensions.
EMBEDDING_URL=http://host.docker.internal:1234/v1

# The model name MUST exactly match the one used to produce the bulk
# embeddings you're loading. Mixing models silently corrupts results.
EMBEDDING_MODEL=nomic-embed-text-v1.5

# Seconds to wait for a single embedding call before failing.
EMBED_TIMEOUT_SECONDS=60

# --- Content paths (mounted read-only into the container) ---
# In Dokploy, mount your NOCIX host directories here:
#   /opt/gospel/gospel-library/  →  /data/gospel-library
#   /opt/gospel/books/           →  /data/books
#   /opt/gospel/embeddings/      →  /data/embeddings
GOSPEL_LIBRARY_PATH=/data/gospel-library
BOOKS_PATH=/data/books
EMBEDDINGS_PATH=/data/embeddings

# --- MCP client binaries ---
# The cross-compiled gospel-mcp binaries are baked into the image at this
# path by the Dockerfile. Do not change unless you know what you're doing.
MCP_BINARIES_PATH=/opt/mcp-binaries

# --- Startup behavior ---
# Re-scan mounted content and upsert into PG on every server start.
# Incremental: unchanged files (mtime+size) are skipped.
# Safe to leave on; first run is slow, subsequent restarts are cheap.
INDEX_ON_STARTUP=true

# Load pre-computed embeddings from EMBEDDINGS_PATH (JSONL) on startup.
# Set to false if you're indexing on the fly via the live embedding server.
BULK_LOAD_EMBEDDINGS=true

# --- Build metadata ---
# Usually set at build time via ldflags; override here only for debugging.
VERSION=dev

# --- DANGER ---
# DEV_MODE=true BYPASSES AUTHENTICATION on every endpoint. Use only for
# local development against a throwaway database. NEVER set this to true
# in Dokploy or any deployed environment.
DEV_MODE=false
